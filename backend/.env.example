# Copy this file to .env and fill in your values
# cp .env.example .env

# ── AI Providers (add at least one) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=generate-a-random-string-here
JWT_EXPIRY_HOURS=720

# ── Encryption (for API keys stored in DB) ────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── URLs ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Rate limiting ─────────────────────────────────────────────────────────────
AUTH_RATE_LIMIT=10        # max login/register attempts
AUTH_RATE_WINDOW=300      # per this many seconds (5 minutes)
CHAT_RATE_LIMIT=30        # max AI queries per user
CHAT_RATE_WINDOW=60       # per this many seconds (1 minute)

# ── Email / SMTP (for scheduled reports) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password   # Gmail: use an App Password, not your account password

# ── Data storage ───────────────────────────────────────────────────────────────
DATA_DIR=./data
MAX_ROWS=100000
MAX_UPLOAD_MB=100
MIN_FREE_DISK_MB=200

# ── Execution sandbox ─────────────────────────────────────────────────────────
EXECUTION_TIMEOUT=30
OPENAI_TIMEOUT=120

# ──────────────────────────────────────────────────────────────────────────────
# OAuth Setup
# Callback URL for all providers: http://localhost:8000/api/auth/oauth/{provider}/callback
# Change host/port to match your BACKEND_URL in production.
# ──────────────────────────────────────────────────────────────────────────────

# ── Google OAuth ───────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorised redirect URI: http://localhost:8000/api/auth/oauth/google/callback
# 5. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft OAuth ────────────────────────────────────────────────────────────
# 1. Go to https://portal.azure.com/ → Azure Active Directory → App registrations → New
# 2. Supported account types: "Accounts in any organizational directory and personal Microsoft accounts"
# 3. Redirect URI (Web): http://localhost:8000/api/auth/oauth/microsoft/callback
# 4. Certificates & secrets → New client secret — copy value immediately
# 5. Permissions: add Microsoft Graph → openid, email, profile, User.Read (delegated)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Yahoo OAuth ────────────────────────────────────────────────────────────────
# 1. Go to https://developer.yahoo.com/apps/create/
# 2. Application Type: Web Application
# 3. Callback Domain: localhost
# 4. API Permissions: OpenID Connect (openid, email, profile)
# 5. Copy Client ID (Consumer Key) and Client Secret (Consumer Secret)
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=

# ── Apple OAuth ────────────────────────────────────────────────────────────────
# 1. Go to https://developer.apple.com/ → Certificates, Identifiers & Profiles
# 2. Identifiers → Register a new App ID → enable "Sign in with Apple"
# 3. Register a Services ID → configure "Sign in with Apple":
#    Return URL: http://localhost:8000/api/auth/oauth/apple/callback
# 4. Keys → Register a new key → enable "Sign in with Apple" → link your App ID
# 5. APPLE_CLIENT_ID = your Services ID (e.g. com.yourapp.signin)
# 6. APPLE_CLIENT_SECRET = generate a JWT using the downloaded .p8 key file:
#    https://developer.apple.com/documentation/sign_in_with_apple/generate_and_validate_tokens
# Note: Apple requires a real domain + HTTPS for production. Localhost works for dev.
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── Stripe Payments ────────────────────────────────────────────────────────────
# 1. Go to https://dashboard.stripe.com/apikeys
# 2. Copy the Secret key (sk_live_... or sk_test_... for testing)
# 3. For webhooks: Stripe Dashboard → Developers → Webhooks → Add endpoint
#    Endpoint URL: https://your-backend.com/api/neurix/webhook
#    Events to listen: checkout.session.completed
# 4. Copy the Signing secret (whsec_...)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
